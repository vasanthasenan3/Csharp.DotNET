<Window x:Class="practiceforundsd.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:practiceforundsd"
        mc:Ignorable="d"
        Title="Login" Height="400" Background="Bisque" Width="300">
    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock FontWeight="Bold" Margin="3,4,0,0" FontSize="14" Text="User Name"></TextBlock>
            <TextBox Name="txtusername" Background="White" BorderThickness="2" BorderBrush="Black" Margin="5,4.8,0,0" Width="170"></TextBox>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock FontWeight="Bold" Margin="3,4,0,0" FontSize="14" Text="Password"></TextBlock>
            <PasswordBox Name="txtpassword" Background="White" BorderThickness="2" BorderBrush="Black" Margin="15,4.8,0,0" Width="170"></PasswordBox>
        </StackPanel>
        <StackPanel>
            <Button Width="130" FontSize="15" Click="Button_Click" Margin="80,5,0,0" BorderBrush="Black" BorderThickness="2" Background="DeepSkyBlue" HorizontalAlignment="Left" Content="Login"></Button>
        </StackPanel>
    </StackPanel>




</Window>
