            <Button Content="2" Name="btn2" Tag="15" Click="btn2_Click" Margin="3,0,0,0" Height="65" FontSize="25"  Width="65" Background="BlanchedAlmond"></Button>
            <Button Content="3" Name="btn3" Tag="20" Click="btn3_Click" Margin="3,0,0,0" Height="65" FontSize="25"  Width="65" Background="BlanchedAlmond"></Button>
            <Button Content="4" Name="btn4" Tag="3" Click="btn4_Click" Margin="3,0,0,0" Height="65" FontSize="25"  Width="65" Background="BlanchedAlmond"></Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,10" HorizontalAlignment="Center">
            <Button Content="5" Name="btn5" Tag="45" Click="btn5_Click" Height="65" FontSize="25"  Width="65" Background="BlanchedAlmond"></Button>
            <Button Content="6" Name="btn6" Tag="4" Click="btn6_Click" Margin="3,0,0,0" Height="65" FontSize="25"  Width="65" Background="BlanchedAlmond"></Button>
