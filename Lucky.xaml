            <Button Content="9" Name="btn9" Tag="100" Click="btn9_Click"  Height="65" FontSize="25"  Width="65" Background="BlanchedAlmond"></Button>
            <Button Content="10" Name="btn10" Tag="oops" Click="btn10_Click"  Margin="3,0,0,0" Height="65" FontSize="25"  Width="65" Background="BlanchedAlmond"></Button>
            <Button Content="11" Name="btn11" Tag="99" Click="btn11_Click" Margin="3,0,0,0" Height="65" FontSize="25"  Width="65" Background="BlanchedAlmond"></Button>
            <Button Content="12" Name="btn12" Tag="88" Click="btn12_Click" Margin="3,0,0,0" Height="65" FontSize="25"  Width="65" Background="BlanchedAlmond"></Button>
