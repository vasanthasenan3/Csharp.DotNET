        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:clses"
        mc:Ignorable="d"
        ResizeMode="NoResize"
         Title="Login"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">
