<Window x:Class="clses.Reg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:clses"
        mc:Ignorable="d"
        xmlns:lang="clr-namespace:clses.Properties"
         Title="Register Screen"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>

        <!-- Label Style -->
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,8,0,3"/>
        </Style>

        <!-- TextBox Border Style -->
        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="DarkGoldenrod"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="DarkGoldenrod"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Border Width="750"
                Padding="25"
                CornerRadius="20"
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side -->
                <StackPanel Grid.Column="0">

                    <TextBlock Text="Employee Registration"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="DarkGoldenrod"
                               Margin="0,0,0,20"/>

                    <Label Content="{x:Static lang:Resources.name}"/>

                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox Name="txtname"
                                 Width="230"/>
                    </Border>

                    <Label Content="{x:Static lang:Resources.adress}"/>

                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox Name="txtadress"
                                 Width="230"/>
                    </Border>

                    <Label Content="{x:Static lang:Resources.position}"/>

                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox Name="txtposition"
                                 Width="230"/>
                    </Border>

                    <Label Content="{x:Static lang:Resources.degree}"/>

                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox Name="txtdegree"
                                 Width="230"/>
                    </Border>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,15,0,0">

                        <Button Content="{x:Static lang:Resources.generate}"
                                Margin="85,0,0,0"
                                Click="Button_Click"/>

                       

                    </StackPanel>

                </StackPanel>

                <!-- Right Side -->
                <Border Grid.Column="2"
                        CornerRadius="15"
                        Background="LightGoldenrodYellow"
                        Padding="10">

                    <TextBox Name="txtoffer"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             FontSize="14"/>

                </Border>

            </Grid>

        </Border>

    </Grid>
